<===> input.scss
@use "sass:list";
@use "sass:meta";
$empty-list: ();

@function foo($args...) {
    @return meta.call(bar, $args...);
}

@function bar($list) {
    @return list.length($list);
}

test {
  test: foo($empty-list);
}
