<===> input.scss
$common-border: "foo";
.nihilo & {
  .dijitMenu {
    border: $common-border;
    .dijitMenuItem {
      color: getColor('text-dark-main');
    }
  }
}

<===> output.css
.nihilo & .dijitMenu {
  border: "foo";
}
.nihilo & .dijitMenu .dijitMenuItem {
  color: getColor("text-dark-main");
}
